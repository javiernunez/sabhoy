# Con el docker compose de este repo el Postgres del host queda en 127.0.0.1:5436
POSTGRES_USER=sabhoy
POSTGRES_PASSWORD=sabhoy
POSTGRES_DB=sabhoy
DATABASE_URL="postgresql://sabhoy:sabhoy@127.0.0.1:5436/sabhoy"

# URL publica (sin barra final) — usada en metadatos, sitemap, canonical, NextAuth
NEXT_PUBLIC_SITE_URL="https://www.sabhoy.es"

# Opcional: verificación de Google Search Console (solo el token del meta `google-site-verification`)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ---- Auth (NextAuth) ----
# Secreto para firmar cookies de sesion; en produccion usa algo unico, p. ej.:
#   openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-largo-para-produccion"
# En produccion: https://www.sabhoy.es  (NO localhost:3003; si no, /admin redirige mal y NextAuth falla)
NEXTAUTH_URL="https://www.sabhoy.es"

# Emails que tendran rol administrador (separados por coma). No son contrasenas: solo
# fijan quien puede entrar a /admin una vez tenga cuenta con ese email.
# Ejemplo: ADMIN_EMAILS=editor@sabhoy.es,otro@correo.com
ADMIN_EMAILS=""

# Opcional: poner a true en produccion para cerrar nuevos registros
# DISABLE_USER_REGISTRATION=false

# ---- Correo (avisos registro / newsletter → info@{dominio}) ----
# SMTP_HOST="mail.javiernunez.com"
# SMTP_PORT="587"
# SMTP_USER="info@sabhoy.es"
# SMTP_PASS=contraseña-del-buzon
# SMTP_SECURE=false
# SMTP_TLS_SERVERNAME="mail.javiernunez.com"

# Opcional: token largo (16+ chars) para crear/editar noticias via API sin cookie de admin
# Cabecera: Authorization: Bearer <token>  o  X-API-Key: <token>
NEWS_API_TOKEN=""

# Opcional: token largo (16+ chars) para integracion de eventos (n8n scraper)
# Cabecera: Authorization: Bearer <token>  o  X-API-Key: <token>
EVENTS_API_TOKEN=""

# ---- Imagenes (admin) ----
# Sin variables S3: se guardan en public/media/ (WebP optimizado) y se sirve desde /media/…
# Hetzner Object Storage (S3): https://docs.hetzner.com/storage/object-storage/ — misma API que S3
# S3_ENDPOINT="https://fsn1.your-objectstorage.com"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET=""
# S3_FORCE_PATH_STYLE=1
# S3_PUBLIC_BASE_URL="https://…/tu-bucket"  # URL publica (lectura) sin barra final; se concatena con media/…
